# Smart Voice Interviewer - Backend Environment Variables

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# JWT signing secret
SECRET_KEY=6faa21a41c5e0d396528bca5085cb6e2dc863b26d74930cde5f5788511938f9f

# PostgreSQL connection string
# Update with your actual database credentials
DATABASE_URL=postgresql://admin:mysecretpassword@localhost:5432/smart_interviewer
# ── Optional (defaults shown) ─────────────────────────────────────────────────

# Server
PORT=8000
WORKERS=1
LOG_LEVEL=info
RELOAD=true

# JWT expiry in minutes (default: 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# PostgreSQL connection pool size
DB_POOL_SIZE=10

# Interview settings
SIMILARITY_THRESHOLD=0.6
NUM_QUESTIONS=3
