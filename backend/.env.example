# Smart Voice Interviewer - Backend Environment Variables
# Copy this file to .env and fill in real values before starting the server.
#
#   cp .env.example .env

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# JWT signing secret. Generate a strong random value, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_use_a_long_random_string_here

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Local example:      postgresql://postgres:password@localhost:5432/smart_interviewer
# Docker example:     postgresql://postgres:password@db:5432/smart_interviewer
# Managed (Supabase): postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/smart_interviewer

# ── Optional (defaults shown) ─────────────────────────────────────────────────

# Server
PORT=8000
WORKERS=1
LOG_LEVEL=info
# Set RELOAD=true in development only – never in production
RELOAD=false

# JWT expiry in minutes (default: 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma-separated list of allowed frontend origins
# Example for local dev:      http://localhost:5173
# Example for production:     https://yourapp.com,https://www.yourapp.com
ALLOWED_ORIGINS=http://localhost:5173

# PostgreSQL connection pool size
DB_POOL_SIZE=10

# Interview settings
SIMILARITY_THRESHOLD=0.6
NUM_QUESTIONS=3
