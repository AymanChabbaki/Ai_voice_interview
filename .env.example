# Environment Configuration for Docker Compose
# Copy this file to .env and update values

# =============================================================================
# Database Configuration
# =============================================================================
# For Docker Compose (these are used by the postgres container)
POSTGRES_USER=interview_user
POSTGRES_PASSWORD=interview_password
POSTGRES_DB=interview_db

# For Backend (Full connection URL)
# Docker: Use service name 'db' as host
DATABASE_URL=postgresql://interview_user:interview_password@db:5432/interview_db

# Local Development (without Docker): Use 'localhost' instead of 'db'
# DATABASE_URL=postgresql://interview_user:interview_password@localhost:5432/interview_db

# Connection Pool
DB_POOL_SIZE=10

# =============================================================================
# Backend Configuration
# =============================================================================
SECRET_KEY=change-this-to-a-random-secret-key-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Interview Settings
SIMILARITY_THRESHOLD=0.6
NUM_QUESTIONS=3

# CORS (comma-separated list)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Server Settings
PORT=8000
WORKERS=1
LOG_LEVEL=info
RELOAD=false
